# ── Code-Compression Bench — environment template ──
# Copy to .env and fill in. NEVER commit .env (gitignored).
#
# The benchmark drives one fixed agent scaffold (open-swe-lite / mini-swe-agent)
# against an OpenAI-compatible model endpoint. You bring your own model + keys.

# ── Model endpoint (the Sonnet-class model every arm runs against) ──
# Any OpenAI-compatible endpoint. Point this at your provider.
OPENAI_BASE_URL=https://api.your-provider.example/v1
OPENAI_API_KEY=sk-REPLACE_ME
# Pin the exact model id used for all arms (keep identical across arms).
MODEL=REPLACE_ME_model_id

# ── Per-arm credentials ──
# Self-hosted arms (no key): Edgee Compressor, RTK, Headroom — see arms/README.md to run their local proxies.

# bear-1.2 (The Token Company) — NO-OP: sales-gated (no self-serve API), excluded from runs.
# Opt back in once access is granted: set BEAR_ENABLED=1 and fill these.
# BEAR_ENABLED=1
# BEAR_API_KEY=REPLACE_ME
# BEAR_BASE_URL=https://api.thetokencompany.example

# Dasein arm — hosted, keyed service (request a key)
DASEIN_API_KEY=dsk_REPLACE_ME
DASEIN_BASE_URL=https://REPLACE_ME

# Woz — paid Claude Code plugin (account/license required to run its arm)
WOZ_API_KEY=REPLACE_ME

# ── Proxy arms ──
# Edgee — HOSTED gateway (sk-edgee key) OR self-host (omit key); set base URL accordingly.
EDGEE_BASE_URL=http://127.0.0.1:8801
EDGEE_API_KEY=REPLACE_ME
# Compresr — Context Gateway: cmp_ key for hosted; omit for local self-host.
COMPRESR_BASE_URL=http://127.0.0.1:8804
COMPRESR_API_KEY=REPLACE_ME
# RTK + Headroom — self-host, no key.
RTK_BASE_URL=http://127.0.0.1:8802
HEADROOM_BASE_URL=http://127.0.0.1:8803

# ── Run config ──
WORKERS=8
COMPRESSION_TARGET_RATIO=0.5
