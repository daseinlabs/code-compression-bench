+#[cfg(test)]
+mod tests {
+    use super::*;
+    use std::sync::Mutex;
+
+    // The config builders read process env; serialize the env-mutating tests so
+    // they can't observe each other's overrides.
+    static ENV_LOCK: Mutex<()> = Mutex::new(());
+
+    #[test]
+    fn anthropic_upstream_defaults_to_anthropic() {
+        let _g = ENV_LOCK.lock().unwrap();
+        std::env::remove_var(ANTHROPIC_UPSTREAM_ENV);
+        let cfg = anthropic_passthrough_config();
+        assert_eq!(cfg.base_url, AnthropicPassthroughConfig::DEFAULT_BASE_URL);
+    }
+
+    #[test]
+    fn anthropic_upstream_env_overrides_base_url() {
+        let _g = ENV_LOCK.lock().unwrap();
+        // A trailing slash is normalized away (the service appends /v1/messages,
+        // verified by gateway-core's own `target_uri_custom_base_url` test).
+        std::env::set_var(ANTHROPIC_UPSTREAM_ENV, "http://127.0.0.1:9123/");
+        let cfg = anthropic_passthrough_config();
+        std::env::remove_var(ANTHROPIC_UPSTREAM_ENV);
+        assert_eq!(cfg.base_url, "http://127.0.0.1:9123");
+    }
+
+    #[test]
+    fn anthropic_upstream_empty_env_is_ignored() {
+        let _g = ENV_LOCK.lock().unwrap();
+        std::env::set_var(ANTHROPIC_UPSTREAM_ENV, "   ");
+        let cfg = anthropic_passthrough_config();
+        std::env::remove_var(ANTHROPIC_UPSTREAM_ENV);
+        assert_eq!(cfg.base_url, AnthropicPassthroughConfig::DEFAULT_BASE_URL);
+    }
+
+    #[test]
+    fn openai_upstream_env_pins_both_endpoints() {
+        let _g = ENV_LOCK.lock().unwrap();
+        std::env::set_var(OPENAI_UPSTREAM_ENV, "http://127.0.0.1:9124");
+        let cfg = openai_passthrough_config();
+        std::env::remove_var(OPENAI_UPSTREAM_ENV);
+        assert_eq!(cfg.api_url, "http://127.0.0.1:9124/v1/responses");
+        assert_eq!(cfg.chatgpt_url, "http://127.0.0.1:9124/v1/responses");
+    }
+}
