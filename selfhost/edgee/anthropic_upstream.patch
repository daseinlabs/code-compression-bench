+/// Env var overriding the Anthropic Messages upstream the local gateway forwards
+/// `/v1/messages` to. Unset → the provider default (`https://api.anthropic.com`).
+///
+/// This is the seam the self-hosted deployments need: the passthrough config has
+/// always supported a `with_base_url` override (unit-tested in
+/// `edgee_gateway_core`), but `start()` historically built the service with the
+/// default config, so there was no way to point the Anthropic upstream anywhere
+/// but `api.anthropic.com`. Reading this env var here wires that override through,
+/// so an operator can route compressed Claude Code `/v1/messages` traffic at their
+/// own Anthropic-compatible endpoint (e.g. a billing/usage gateway) instead.
+const ANTHROPIC_UPSTREAM_ENV: &str = "EDGEE_ANTHROPIC_UPSTREAM";
+
+/// Env var overriding the OpenAI Responses upstream the local gateway forwards
+/// `/v1/responses` to. Unset → the provider defaults. Both the Platform and the
+/// ChatGPT-backend endpoints are pinned to this value when set (mirrors
+/// `OpenAIPassthroughConfig::with_api_url` + `with_chatgpt_url`).
+const OPENAI_UPSTREAM_ENV: &str = "EDGEE_OPENAI_UPSTREAM";
+
+/// Build the Anthropic passthrough config, honoring [`ANTHROPIC_UPSTREAM_ENV`].
+///
+/// Returns the default config (production `api.anthropic.com`) when the env var
+/// is unset or empty, so behavior is unchanged unless an operator opts in.
+fn anthropic_passthrough_config() -> AnthropicPassthroughConfig {
+    match std::env::var(ANTHROPIC_UPSTREAM_ENV) {
+        Ok(url) if !url.trim().is_empty() => {
+            let url = url.trim().trim_end_matches('/').to_owned();
+            tracing::info!(upstream = %url, env = ANTHROPIC_UPSTREAM_ENV, "anthropic upstream overridden");
+            AnthropicPassthroughConfig::default().with_base_url(url)
+        }
+        _ => AnthropicPassthroughConfig::default(),
+    }
+}
+
+/// Build the OpenAI passthrough config, honoring [`OPENAI_UPSTREAM_ENV`].
+///
+/// Pins BOTH OpenAI endpoints to the override when set; otherwise returns the
+/// production defaults unchanged. The override base is suffixed with
+/// `/v1/responses` (the path the production URLs carry) so a bare base URL works.
+fn openai_passthrough_config() -> OpenAIPassthroughConfig {
+    match std::env::var(OPENAI_UPSTREAM_ENV) {
+        Ok(url) if !url.trim().is_empty() => {
+            let base = url.trim().trim_end_matches('/');
+            let responses = format!("{base}/v1/responses");
+            tracing::info!(upstream = %responses, env = OPENAI_UPSTREAM_ENV, "openai upstream overridden");
+            OpenAIPassthroughConfig::default()
+                .with_api_url(responses.clone())
+                .with_chatgpt_url(responses)
+        }
+        _ => OpenAIPassthroughConfig::default(),
+    }
+}
